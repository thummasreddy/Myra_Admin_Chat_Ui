    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.56.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.13"
  },
  "keywords": [
    "react",
    "chat-widget",
    "myra",
    "ai-assistant",
    "fastapi",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
