{
  "name": "@myra/chat-widget",
  "version": "1.0.0",
  "description": "Reusable React + TypeScript chat widget for Myra AI Assistant with Python FastAPI backend",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
