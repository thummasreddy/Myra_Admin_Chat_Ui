{
  "name": "myra-platform-contract",
  "version": "2026-06-04",
  "gateway": {
    "basePath": "/api/v1",
    "routes": {
      "/api/v1/tenants/*": {
        "service": "tenant-service"
      },
      "/api/v1/chat/*": {
        "service": "chat-service"
      },
      "/api/v1/knowledge/*": {
        "service": "knowledge-service"
      },
      "/api/v1/leads/*": {
        "service": "lead-service"
      },
      "/api/v1/analytics/*": {
        "service": "analytics-service"
      }
    },
    "crossCutting": [
      "cors",
      "request_id",
      "rate_limit",
      "security_headers",
      "structured_logging",
      "metrics",
      "health_aggregation"
    ]
  },
  "headers": {
    "requestId": "X-Request-Id",
    "adminSecret": "X-Admin-Secret",
    "tenantId": "X-Tenant-Id",
    "apiKey": "X-API-Key"
  },
  "canonicalFields": {
    "chatRequest": {
      "required": ["tenant_id", "session_id", "message"],
      "optional": ["source_url", "metadata"]
    },
    "chatResponse": {
      "envelope": "success/data/message",
      "replyPath": ["data", "reply"],
      "requiredData": ["session_id", "reply"],
      "optionalData": [
        "user_message_id",
        "assistant_message_id",
        "confidence_score",
        "source_documents",
        "suggested_prompts"
      ],
      "transitionFallback": ["data", "assistant_message"]
    },
    "leadRequest": {
      "required": ["tenant_id", "session_id", "name", "email", "phone", "message"],
      "optional": ["source_url", "metadata", "lead_type"],
      "defaults": {
        "lead_type": "GENERAL"
      },
      "forbidden": ["mobile", "interest"]
    },
    "tenantConfig": {
      "publicCase": "camelCase",
      "adminCase": "snake_case",
      "publicRequired": ["tenantId"],
      "publicOptional": [
        "tenantName",
        "assistantName",
        "assistantIntro",
        "brandColor",
        "fallbackMessage",
        "responseStyle",
        "suggestedPrompts",
        "enableWebSearch",
        "enableLeadCapture",
        "enableSuggestedPrompts",
        "status"
      ],
      "adminMappings": {
        "tenantId": "tenant_id",
        "tenantName": "tenant_name",
        "websiteUrl": "website_url",
        "assistantName": "assistant_name",
        "assistantIntro": "assistant_intro",
        "brandColor": "brand_color",
        "systemPrompt": "system_prompt",
        "allowedTopics": "allowed_topics",
        "fallbackMessage": "fallback_message",
        "responseStyle": "response_style",
        "suggestedPrompts": "suggested_prompts",
        "enableWebSearch": "enable_web_search",
        "enableLeadCapture": "enable_lead_capture",
        "enableSuggestedPrompts": "enable_suggested_prompts",
        "status": "status"
      }
    },
    "responseStyles": ["PROFESSIONAL", "FRIENDLY", "CASUAL", "FORMAL"]
  },
  "sharedBackendLibrary": {
    "folder": "shared",
    "modules": [
      "config_base.py",
      "db_utils.py",
      "api_response.py",
      "exceptions_base.py",
      "logging_utils.py",
      "idempotency_base.py",
      "http_client.py"
    ]
  },
  "productionRequirements": [
    "migrations_run_before_start",
    "no_mock_providers",
    "no_default_secrets",
    "object_storage_required_for_knowledge_documents",
    "redis_required_for_tenant_cache",
    "redis_required_for_idempotency",
    "request_id_propagation",
    "json_logs",
    "metrics_endpoint_per_service",
    "health_aggregation_endpoint"
  ]
}
