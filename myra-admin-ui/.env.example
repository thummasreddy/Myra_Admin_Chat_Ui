# Myra frontend environment
#
# Recommended architecture:
# - Admin portal uses the backend gateway under /api/v1/*
# - Public widget uses the same gateway for /api/chat and /api/leads
# - Optional service URLs below are for local direct-service development only

VITE_API_BASE_URL=http://localhost:8000/api/v1

# Optional direct-service overrides. Leave blank when using the gateway pattern.
# VITE_TENANT_API_URL=http://localhost:8001/api/v1
# VITE_ADMIN_API_URL=http://localhost:8002/api/v1
# VITE_KNOWLEDGE_API_URL=http://localhost:8003/api/v1
# VITE_ANALYTICS_API_URL=http://localhost:8004/api/v1
# VITE_LEAD_API_URL=http://localhost:8005/api/v1
# VITE_CHAT_API_URL=http://localhost:8006/api/v1

# API resilience
VITE_API_TIMEOUT_MS=12000
VITE_API_RETRY_ATTEMPTS=2
VITE_API_RETRY_BASE_DELAY_MS=300
VITE_API_RATE_LIMIT_PER_MINUTE=120

# Security and compatibility
# Widget requests may include this as X-Api-Key when the backend supports public widget API keys.
# VITE_PUBLIC_WIDGET_KEY=local-widget-key

# Runtime behavior
VITE_ENABLE_DEMO_FALLBACKS=true
VITE_ENABLE_API_LOGGING=false
VITE_REQUIRE_ENV_VALIDATION=false

# Production monitoring
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
