# All traffic routed through the API gateway
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_ANALYTICS_API_URL=http://localhost:8080/api/v1/analytics
VITE_ADMIN_API_URL=http://localhost:8080/api/v1/tenants

# API resilience
VITE_API_TIMEOUT_MS=12000
VITE_API_RETRY_ATTEMPTS=2
VITE_API_RETRY_BASE_DELAY_MS=300
VITE_API_RATE_LIMIT_PER_MINUTE=120

# Runtime behavior
VITE_ENABLE_DEMO_FALLBACKS=false
VITE_ENABLE_API_LOGGING=false
VITE_REQUIRE_ENV_VALIDATION=false

# Production monitoring
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
